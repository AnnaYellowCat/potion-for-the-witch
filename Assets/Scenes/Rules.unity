    m_MaxSize: 300
    m_Alignment: 1
    m_AlignByGeometry: 1
    m_RichText: 1
    m_HorizontalOverflow: 0
    m_VerticalOverflow: 0
    m_LineSpacing: 1
  m_Text: "\u0427\u0442\u043E\u0431\u044B \u043F\u043E\u0434\u043D\u044F\u0442\u044C
    \u043F\u0440\u0435\u0434\u043C\u0435\u0442, \u043F\u043E\u0434\u043E\u0439\u0434\u0438
    \u043A \u043D\u0435\u043C\u0443 \u043F\u043E\u0431\u043B\u0438\u0436\u0435. \u0414\u0430\u0431\u044B
    \u043F\u0440\u043E\u043F\u0443\u0441\u0442\u0438\u0442\u044C, \u043F\u0435\u0440\u0435\u043F\u0440\u044B\u0433\u0438\u0432\u0430\u0439
    \u0435\u0433\u043E!\n\n\n\n\n\n\u0414\u043B\u044F \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F
    \u0441\u0443\u043D\u0434\u0443\u043A\u0430 \u043D\u0443\u0436\u043D\u043E \u043F\u0440\u0438\u0431\u043B\u0438\u0437\u0438\u0442\u044C\u0441\u044F
    \u043A \u043D\u0435\u043C\u0443 \u0438 \u043D\u0430\u0436\u0430\u0442\u044C \u043D\u0430
    E[\u0443]. \u0427\u0442\u043E\u0431\u044B \u0437\u0430\u0431\u0440\u0430\u0442\u044C
    \u0441 \u0441\u043E\u0431\u043E\u0439 \u043F\u0440\u0435\u0434\u043C\u0435\u0442,
    \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0439  E[\u0443] \u0435\u0449\u0435
    \u0440\u0430\u0437.\n\n\n\n\n\n\u0427\u0442\u043E\u0431\u044B \u0434\u0430\u0442\u044C
    \u043E\u0442\u043F\u043E\u0440 \u0432\u0440\u0430\u0433\u0430\u043C, \u0441\u043C\u0435\u043B\u043E
    \u0436\u043C\u0438 \u043D\u0430 F[\u0430].\n"
